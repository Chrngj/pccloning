@page "/pcmanagement"
@model PCGroupCloningApp.Pages.PCManagementModel
@{
    ViewData["Title"] = "PC Management";
}

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="fas fa-desktop"></i> PC Management
            </h2>
        </div>
    </div>

    <!-- PC Return/Reset Section -->
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-undo"></i> PC Return - Move to NyRullet
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        <i class="fas fa-info-circle"></i>
                        Search for a PC to move it to the "Nyrullet" OU.
                    </p>

                    <!-- Computer Search -->
                    <div class="mb-3">
                        <label for="computerSearch" class="form-label">Search Computer</label>
                        <input type="text" id="computerSearch" class="form-control"
                               placeholder="Type computer name..." autocomplete="off">
                        <div id="computerDropdown" class="dropdown-menu w-100" style="display: none;"></div>
                    </div>

                    <!-- Selected Computer Display -->
                    <div id="selectedComputerInfo" class="alert alert-info mb-3" style="display: none;">
                        <strong>Selected:</strong> <span id="selectedComputerName"></span><br>
                        <small>Current OU: <span id="currentOU"></span></small>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2">
                        <button type="button" id="resetButton" class="btn btn-warning btn-lg" disabled>
                            <i class="fas fa-sync-alt"></i> Move to NyRullet
                        </button>
                    </div>

                    <!-- Results -->
                    <div id="resultMessage" class="mt-3" style="display: none;">
                        <!-- Results will be shown here -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Future SCCM Delete Section (Placeholder) -->
        <div class="col-md-6">
            <div class="card bg-light">
                <div class="card-header">
                    <h5 class="mb-0 text-muted">
                        <i class="fas fa-trash-alt"></i> SCCM Management
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted text-center py-5">
                        <i class="fas fa-tools fa-3x mb-3"></i><br>
                        <strong>Coming Soon</strong><br>
                        SCCM delete functionality will be available here in a future update.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Operations -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-history"></i> Recent PC Management Operations
                    </h5>
                </div>
                <div class="card-body">
                    <div id="recentOperations">
                        <div class="text-center text-muted py-3">
                            <i class="fas fa-spinner fa-spin"></i> Loading recent operations...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // PC Management JavaScript
    let selectedComputer = '';
    let searchTimeout = null;

    // Computer search
    document.getElementById('computerSearch').addEventListener('input', function(e) {
        const term = e.target.value;
        clearTimeout(searchTimeout);

        if (term.length < 2) {
            hideDropdown();
            return;
        }

        searchTimeout = setTimeout(async () => {
            await searchComputers(term);
        }, 300);
    });

    // Keyboard navigation
    document.getElementById('computerSearch').addEventListener('keydown', function(e) {
        const dropdown = document.getElementById('computerDropdown');
        const items = dropdown.querySelectorAll('.dropdown-item');

        if (items.length === 0) return;

        let selectedIndex = Array.from(items).findIndex(item => item.classList.contains('dropdown-item-highlighted'));

        switch(e.key) {
            case 'ArrowDown':
                e.preventDefault();
                selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
                updateHighlight(items, selectedIndex);
                break;

            case 'ArrowUp':
                e.preventDefault();
                selectedIndex = Math.max(selectedIndex - 1, 0);
                updateHighlight(items, selectedIndex);
                break;

            case 'Enter':
                e.preventDefault();
                if (selectedIndex >= 0 && selectedIndex < items.length) {
                    items[selectedIndex].click();
                }
                break;

            case 'Escape':
                e.preventDefault();
                hideDropdown();
                break;
        }
    });

    async function searchComputers(term) {
        try {
            const response = await fetch(`/api/computer/search?term=${encodeURIComponent(term)}`);
            const computers = await response.json();
            displayComputerDropdown(computers);
        } catch (error) {
            console.error('Error searching computers:', error);
        }
    }

    function displayComputerDropdown(computers) {
        const dropdown = document.getElementById('computerDropdown');

        if (computers.length === 0) {
            dropdown.innerHTML = '<div class="dropdown-item-text">No computers found</div>';
        } else {
            dropdown.innerHTML = computers.map(computer =>
                `<button type="button" class="dropdown-item" onclick="selectComputer('${computer}')">${computer}</button>`
            ).join('');
        }

        dropdown.style.display = 'block';
    }

    async function selectComputer(computerName) {
        selectedComputer = computerName;

        document.getElementById('computerSearch').value = computerName;
        document.getElementById('selectedComputerName').textContent = computerName;
        hideDropdown();

        // Get current OU
        try {
            const response = await fetch(`/api/computer/${encodeURIComponent(computerName)}/ou`);
            const data = await response.json();
            document.getElementById('currentOU').textContent = data.ou || 'Unknown';
        } catch (error) {
            console.error('Error getting computer OU:', error);
            document.getElementById('currentOU').textContent = 'Error loading OU';
        }

        document.getElementById('selectedComputerInfo').style.display = 'block';
        document.getElementById('resetButton').disabled = false;

        // Clear any previous result message
        document.getElementById('resultMessage').style.display = 'none';
    }

    // Reset PC button
    document.getElementById('resetButton').addEventListener('click', async function() {
        if (!selectedComputer) {
            showResult('Please select a computer first.', 'danger');
            return;
        }

        if (!confirm(`Are you sure you want to reset ${selectedComputer} and move it to NyRullet?`)) {
            return;
        }

        const button = this;
        const originalText = button.innerHTML;
        button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
        button.disabled = true;

        try {
            const response = await fetch('/api/pcmanagement/reset', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    computerName: selectedComputer
                })
            });

            const result = await response.json();

            if (result.success) {
                showResult(`✅ Successfully reset ${selectedComputer} - moved to NyRullet OU`, 'success');
                // Clear selection
                selectedComputer = '';
                document.getElementById('computerSearch').value = '';
                document.getElementById('selectedComputerInfo').style.display = 'none';

                // Reload recent operations
                await loadRecentOperations();
            } else {
                showResult(`❌ Failed to reset PC: ${result.message}`, 'danger');
            }
        } catch (error) {
            console.error('Error resetting PC:', error);
            showResult('❌ Network error occurred during reset operation.', 'danger');
        } finally {
            button.innerHTML = originalText;
            button.disabled = selectedComputer === '';
        }
    });

    function showResult(message, type) {
        const resultDiv = document.getElementById('resultMessage');
        resultDiv.innerHTML = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;
        resultDiv.style.display = 'block';
    }

    function updateHighlight(items, selectedIndex) {
        items.forEach(item => item.classList.remove('dropdown-item-highlighted'));

        if (selectedIndex >= 0 && selectedIndex < items.length) {
            items[selectedIndex].classList.add('dropdown-item-highlighted');
            items[selectedIndex].scrollIntoView({
                block: 'nearest',
                behavior: 'smooth'
            });
        }
    }

    function hideDropdown() {
        document.getElementById('computerDropdown').style.display = 'none';
    }

    // Hide dropdown when clicking outside
    document.addEventListener('click', function(e) {
        if (!e.target.closest('#computerSearch') && !e.target.closest('#computerDropdown')) {
            hideDropdown();
        }
    });

    // Load recent operations
    async function loadRecentOperations() {
        try {
            const response = await fetch('/api/pcmanagement/recent');
            const operations = await response.json();

            const container = document.getElementById('recentOperations');

            if (operations.length === 0) {
                container.innerHTML = '<p class="text-muted text-center">No recent operations</p>';
            } else {
                const tableHtml = `
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Computer</th>
                                    <th>Operation</th>
                                    <th>User</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${operations.map(op => `
                                    <tr>
                                        <td><small>${new Date(op.timestamp).toLocaleString()}</small></td>
                                        <td><strong>${op.targetComputer}</strong></td>
                                        <td><span class="badge bg-info">${op.operation}</span></td>
                                        <td>${op.username}</td>
                                        <td>
                                            ${op.success
                                                ? '<span class="badge bg-success">Success</span>'
                                                : '<span class="badge bg-danger">Failed</span>'}
                                        </td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                `;
                container.innerHTML = tableHtml;
            }
        } catch (error) {
            console.error('Error loading recent operations:', error);
            document.getElementById('recentOperations').innerHTML =
                '<p class="text-danger text-center">Error loading recent operations</p>';
        }
    }

    // Load recent operations on page load
    document.addEventListener('DOMContentLoaded', function() {
        loadRecentOperations();
    });
</script>

<style>
    .dropdown-menu {
        max-height: 200px;
        overflow-y: auto;
        z-index: 1050;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
    }

    .dropdown-item-highlighted {
        background-color: #0d6efd !important;
        color: white !important;
    }

    .dropdown-item {
        transition: background-color 0.1s ease;
        padding: 0.5rem 1rem;
        border: none;
        background: none;
        width: 100%;
        text-align: left;
    }

    .dropdown-item:hover {
        background-color: #f8f9fa;
    }

    .card {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    .card-header {
        background-color: #f8f9fa;
        border-bottom: 1px solid rgba(0,0,0,.125);
    }

    .btn-warning {
        color: #000;
    }

    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
