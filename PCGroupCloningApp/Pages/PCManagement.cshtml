@page "/pcmanagement"
@model PCGroupCloningApp.Pages.PCManagementModel
@{
    ViewData["Title"] = "PC Management";
}

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="fas fa-desktop"></i> PC Management
            </h2>
        </div>
    </div>

    <!-- Row 1: NyRullet + Delete PC -->
    <div class="row">
        <!-- PC Return/Reset Section (EXISTING) -->
        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-undo"></i> PC Return - Move to NyRullet
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        <i class="fas fa-info-circle"></i>
                        Search for a PC to move it to the "NyRullet" OU.
                    </p>

                    <div class="mb-3">
                        <label for="nyrulletSearch" class="form-label">Search Computer</label>
                        <input type="text" id="nyrulletSearch" class="form-control"
                               placeholder="Type computer name..." autocomplete="off">
                        <div id="nyrulletDropdown" class="dropdown-menu w-100" style="display: none;"></div>
                    </div>

                    <div id="nyrulletInfo" class="alert alert-info mb-3" style="display: none;">
                        <strong>Selected:</strong> <span id="nyrulletName"></span><br>
                        <small>Current OU: <span id="nyrulletOU"></span></small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button" id="nyrulletButton" class="btn btn-warning btn-lg" disabled>
                            <i class="fas fa-sync-alt"></i> Move to NyRullet
                        </button>
                    </div>

                    <div id="nyrulletResult" class="mt-3" style="display: none;"></div>
                </div>
            </div>
        </div>

        <!-- Delete PC Section (NEW) -->
        <div class="col-md-6 mb-3">
            <div class="card h-100">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-trash-alt"></i> Delete PC
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        <i class="fas fa-info-circle"></i>
                        Deletes PC from SCCM and Active Directory. This action cannot be undone!
                    </p>

                    <div class="mb-3">
                        <label for="deleteSearch" class="form-label">Search Computer</label>
                        <input type="text" id="deleteSearch" class="form-control"
                               placeholder="Type computer name..." autocomplete="off">
                        <div id="deleteDropdown" class="dropdown-menu w-100" style="display: none;"></div>
                    </div>

                    <div id="deleteInfo" style="display: none;">
                        <div class="alert alert-info mb-2">
                            <strong>Selected:</strong> <span id="deleteName"></span><br>
                            <small>AD OU: <span id="deleteOU"></span></small><br>
                            <small>AD Groups: <span id="deleteGroups"></span></small>
                        </div>
                        <div id="deleteSCCMInfo" class="alert alert-secondary mb-2">
                            <small><i class="fas fa-spinner fa-spin"></i> Loading SCCM info...</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="deleteDescription" class="form-label">Description <span class="text-danger">*</span></label>
                        <textarea id="deleteDescription" class="form-control" rows="2"
                                  placeholder="E.g. PC defective, employee left, etc."></textarea>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="deleteStolen">
                        <label class="form-check-label" for="deleteStolen">
                            <i class="fas fa-exclamation-triangle text-danger"></i>
                            <strong>PC is stolen</strong>
                            <small class="form-text text-muted d-block">
                                If checked: PC will be moved to the Stolen OU in AD instead of being deleted
                            </small>
                        </label>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button" id="deleteButton" class="btn btn-danger btn-lg" disabled>
                            <i class="fas fa-trash-alt"></i> Delete PC
                        </button>
                    </div>

                    <div id="deleteResult" class="mt-3" style="display: none;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Move OSD Role -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-exchange-alt"></i> Move OSD Role (SCCM)
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">
                        <i class="fas fa-info-circle"></i>
                        Move a PC between OSD Role collections in SCCM. Controls which configuration the PC receives during PXE boot.
                    </p>

                    <div class="mb-3">
                        <label for="moveOSDSearch" class="form-label">Search Computer</label>
                        <input type="text" id="moveOSDSearch" class="form-control"
                               placeholder="Type computer name..." autocomplete="off">
                        <div id="moveOSDDropdown" class="dropdown-menu w-100" style="display: none;"></div>
                    </div>

                    <div id="moveOSDInfo" style="display: none;">
                        <div class="alert alert-info mb-2">
                            <strong>Selected:</strong> <span id="moveOSDName"></span>
                        </div>
                        <div id="moveOSDCurrentRole" class="alert alert-secondary mb-2">
                            <small><i class="fas fa-spinner fa-spin"></i> Loading current role...</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="moveOSDTarget" class="form-label">New OSD Role</label>
                        <select id="moveOSDTarget" class="form-select" disabled>
                            <option value="">Select a role...</option>
                            <option value="PS30062F">#OSD - Role - Administrativ (ADM)</option>
                            <option value="PS3006C8">#OSD - Role - Administrativ (ADMUP)</option>
                            <option value="PS300666">#OSD - Role - Basis PC (BPC)</option>
                            <option value="PS300643">#OSD - Role - Politiker (POL)</option>
                            <option value="PS300645">#OSD - Role - Valg (VAL)</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button" id="moveOSDButton" class="btn btn-primary btn-lg" disabled>
                            <i class="fas fa-exchange-alt"></i> Move Role
                        </button>
                    </div>

                    <div id="moveOSDResult" class="mt-3" style="display: none;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Operations -->
    <div class="row mt-2">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-history"></i> Recent PC Management Operations
                    </h5>
                </div>
                <div class="card-body">
                    <div id="recentOperations">
                        <div class="text-center text-muted py-3">
                            <i class="fas fa-spinner fa-spin"></i> Loading recent operations...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // =====================================================
    // SHARED: Computer search helper
    // =====================================================
    function setupComputerSearch(inputId, dropdownId, onSelect) {
        let timeout = null;
        const input = document.getElementById(inputId);
        const dropdown = document.getElementById(dropdownId);

        input.addEventListener('input', function(e) {
            clearTimeout(timeout);
            if (e.target.value.length < 2) { dropdown.style.display = 'none'; return; }
            timeout = setTimeout(async () => {
                const response = await fetch(`/api/computer/search?term=${encodeURIComponent(e.target.value)}`);
                const computers = await response.json();
                if (computers.length === 0) {
                    dropdown.innerHTML = '<div class="dropdown-item-text">No computers found</div>';
                } else {
                    dropdown.innerHTML = computers.map(c =>
                        `<button type="button" class="dropdown-item" data-name="${c}">${c}</button>`
                    ).join('');
                    dropdown.querySelectorAll('.dropdown-item').forEach(item => {
                        item.addEventListener('click', () => {
                            input.value = item.dataset.name;
                            dropdown.style.display = 'none';
                            onSelect(item.dataset.name);
                        });
                    });
                }
                dropdown.style.display = 'block';
            }, 300);
        });

        input.addEventListener('keydown', function(e) {
            const items = dropdown.querySelectorAll('.dropdown-item');
            if (items.length === 0) return;
            let idx = Array.from(items).findIndex(i => i.classList.contains('dropdown-item-highlighted'));
            if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx - 1, 0); }
            else if (e.key === 'Enter') { e.preventDefault(); if (idx >= 0) items[idx].click(); return; }
            else if (e.key === 'Escape') { dropdown.style.display = 'none'; return; }
            else return;
            items.forEach(i => i.classList.remove('dropdown-item-highlighted'));
            if (idx >= 0) { items[idx].classList.add('dropdown-item-highlighted'); items[idx].scrollIntoView({ block: 'nearest' }); }
        });

        document.addEventListener('click', function(e) {
            if (!e.target.closest(`#${inputId}`) && !e.target.closest(`#${dropdownId}`)) {
                dropdown.style.display = 'none';
            }
        });
    }

    function showResult(elementId, message, type) {
        const div = document.getElementById(elementId);
        div.innerHTML = `<div class="alert alert-${type}">${message}</div>`;
        div.style.display = 'block';
    }

    // =====================================================
    // SECTION 1: NyRullet
    // =====================================================
    let nyrulletComputer = '';

    setupComputerSearch('nyrulletSearch', 'nyrulletDropdown', async function(name) {
        nyrulletComputer = name;
        document.getElementById('nyrulletName').textContent = name;
        try {
            const r = await fetch(`/api/computer/${encodeURIComponent(name)}/ou`);
            const d = await r.json();
            document.getElementById('nyrulletOU').textContent = d.ou || 'Unknown';
        } catch { document.getElementById('nyrulletOU').textContent = 'Error'; }
        document.getElementById('nyrulletInfo').style.display = 'block';
        document.getElementById('nyrulletButton').disabled = false;
        document.getElementById('nyrulletResult').style.display = 'none';
    });

    document.getElementById('nyrulletButton').addEventListener('click', async function() {
        if (!nyrulletComputer || !confirm(`Are you sure you want to move ${nyrulletComputer} to NyRullet?`)) return;
        const btn = this; const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...'; btn.disabled = true;
        try {
            const r = await fetch('/api/pcmanagement/reset', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ computerName: nyrulletComputer })
            });
            const result = await r.json();
            showResult('nyrulletResult', result.success ? `✅ ${result.message}` : `❌ ${result.message}`, result.success ? 'success' : 'danger');
            if (result.success) { nyrulletComputer = ''; document.getElementById('nyrulletSearch').value = ''; document.getElementById('nyrulletInfo').style.display = 'none'; loadRecentOperations(); }
        } catch (e) { showResult('nyrulletResult', '❌ Network error', 'danger'); }
        finally { btn.innerHTML = orig; btn.disabled = !nyrulletComputer; }
    });

    // =====================================================
    // SECTION 2: Delete PC
    // =====================================================
    let deleteComputer = '';

    setupComputerSearch('deleteSearch', 'deleteDropdown', async function(name) {
        deleteComputer = name;
        document.getElementById('deleteName').textContent = name;

        // Get AD info
        try {
            const ouR = await fetch(`/api/computer/${encodeURIComponent(name)}/ou`);
            const ouD = await ouR.json();
            document.getElementById('deleteOU').textContent = ouD.ou || 'Unknown';
        } catch { document.getElementById('deleteOU').textContent = 'Error'; }

        try {
            const grR = await fetch(`/api/computer/${encodeURIComponent(name)}/groups`);
            const groups = await grR.json();
            document.getElementById('deleteGroups').textContent = groups.length > 0 ? `${groups.length} groups` : 'None';
        } catch { document.getElementById('deleteGroups').textContent = 'Error'; }

        document.getElementById('deleteInfo').style.display = 'block';

        // Get SCCM info
        document.getElementById('deleteSCCMInfo').innerHTML = '<small><i class="fas fa-spinner fa-spin"></i> Loading SCCM info...</small>';
        try {
            const sccmR = await fetch(`/api/pcmanagement/${encodeURIComponent(name)}/sccminfo`);
            const sccm = await sccmR.json();
            if (sccm.found) {
                const collections = sccm.osdCollections.map(c => c.name).join(', ') || 'No OSD collections';
                document.getElementById('deleteSCCMInfo').innerHTML =
                    `<small><i class="fas fa-server"></i> <strong>SCCM:</strong> Found (ResourceID: ${sccm.resourceId})<br>OSD Collections: ${collections}</small>`;
            } else {
                document.getElementById('deleteSCCMInfo').innerHTML =
                    '<small><i class="fas fa-exclamation-circle text-warning"></i> Not found in SCCM</small>';
            }
        } catch {
            document.getElementById('deleteSCCMInfo').innerHTML =
                '<small><i class="fas fa-exclamation-triangle text-danger"></i> Error loading SCCM info</small>';
        }

        document.getElementById('deleteButton').disabled = false;
        document.getElementById('deleteResult').style.display = 'none';
    });

    document.getElementById('deleteButton').addEventListener('click', async function() {
        const description = document.getElementById('deleteDescription').value.trim();
        if (!deleteComputer) return;
        if (!description) { alert('Description is required!'); return; }

        const isStolen = document.getElementById('deleteStolen').checked;
        const action = isStolen
            ? `move ${deleteComputer} to the Stolen OU (AD) and delete from SCCM`
            : `PERMANENTLY DELETE ${deleteComputer} from AD and SCCM`;

        if (!confirm(`Are you sure you want to ${action}?\n\nDescription: ${description}\n\nThis action CANNOT be undone!`)) return;

        const btn = this; const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...'; btn.disabled = true;
        try {
            const r = await fetch('/api/pcmanagement/delete', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ computerName: deleteComputer, description: description, isStolen: isStolen })
            });
            const result = await r.json();
            showResult('deleteResult', result.success ? `✅ ${result.message}` : `❌ ${result.message}`, result.success ? 'success' : 'danger');
            if (result.success) {
                deleteComputer = '';
                document.getElementById('deleteSearch').value = '';
                document.getElementById('deleteInfo').style.display = 'none';
                document.getElementById('deleteDescription').value = '';
                document.getElementById('deleteStolen').checked = false;
                loadRecentOperations();
            }
        } catch (e) { showResult('deleteResult', '❌ Network error during deletion', 'danger'); }
        finally { btn.innerHTML = orig; btn.disabled = !deleteComputer; }
    });

    // =====================================================
    // SECTION 3: Move OSD Role
    // =====================================================
    let moveOSDComputer = '';

    setupComputerSearch('moveOSDSearch', 'moveOSDDropdown', async function(name) {
        moveOSDComputer = name;
        document.getElementById('moveOSDName').textContent = name;
        document.getElementById('moveOSDInfo').style.display = 'block';

        // Get current SCCM role
        document.getElementById('moveOSDCurrentRole').innerHTML = '<small><i class="fas fa-spinner fa-spin"></i> Loading current role...</small>';
        try {
            const r = await fetch(`/api/pcmanagement/${encodeURIComponent(name)}/sccminfo`);
            const sccm = await r.json();
            if (sccm.found) {
                if (sccm.currentRole) {
                    document.getElementById('moveOSDCurrentRole').innerHTML =
                        `<small><i class="fas fa-tag"></i> <strong>Current role:</strong> ${sccm.currentRole.name}</small>`;
                } else if (sccm.hasNoRole) {
                    document.getElementById('moveOSDCurrentRole').innerHTML =
                        '<small><i class="fas fa-question-circle text-warning"></i> <strong>Current role:</strong> #OSD - Role - No Role assigned</small>';
                } else {
                    document.getElementById('moveOSDCurrentRole').innerHTML =
                        '<small><i class="fas fa-question-circle text-warning"></i> No role assigned</small>';
                }
                document.getElementById('moveOSDTarget').disabled = false;
            } else {
                document.getElementById('moveOSDCurrentRole').innerHTML =
                    '<small><i class="fas fa-exclamation-circle text-danger"></i> Not found in SCCM - cannot move</small>';
                document.getElementById('moveOSDTarget').disabled = true;
            }
        } catch {
            document.getElementById('moveOSDCurrentRole').innerHTML =
                '<small><i class="fas fa-exclamation-triangle text-danger"></i> Error looking up SCCM info</small>';
        }

        document.getElementById('moveOSDResult').style.display = 'none';
        updateMoveOSDButton();
    });

    document.getElementById('moveOSDTarget').addEventListener('change', updateMoveOSDButton);

    function updateMoveOSDButton() {
        document.getElementById('moveOSDButton').disabled = !moveOSDComputer || !document.getElementById('moveOSDTarget').value;
    }

    document.getElementById('moveOSDButton').addEventListener('click', async function() {
        const targetId = document.getElementById('moveOSDTarget').value;
        const targetName = document.getElementById('moveOSDTarget').selectedOptions[0].text;
        if (!moveOSDComputer || !targetId) return;
        if (!confirm(`Move ${moveOSDComputer} to ${targetName}?`)) return;

        const btn = this; const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Moving...'; btn.disabled = true;
        try {
            const r = await fetch('/api/pcmanagement/moveosd', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ computerName: moveOSDComputer, targetCollectionId: targetId })
            });
            const result = await r.json();
            showResult('moveOSDResult', result.success ? `✅ ${result.message}` : `❌ ${result.message}`, result.success ? 'success' : 'danger');
            if (result.success) { loadRecentOperations(); }
        } catch (e) { showResult('moveOSDResult', '❌ Network error', 'danger'); }
        finally { btn.innerHTML = orig; updateMoveOSDButton(); }
    });

    // =====================================================
    // Recent Operations
    // =====================================================
    async function loadRecentOperations() {
        try {
            const r = await fetch('/api/pcmanagement/recent');
            const ops = await r.json();
            const container = document.getElementById('recentOperations');
            if (ops.length === 0) {
                container.innerHTML = '<p class="text-muted text-center">No recent operations</p>';
            } else {
                container.innerHTML = `
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead><tr><th>Time</th><th>Computer</th><th>Operation</th><th>Destination</th><th>User</th><th>Status</th></tr></thead>
                            <tbody>${ops.map(op => `
                                <tr>
                                    <td><small>${new Date(op.timestamp).toLocaleString()}</small></td>
                                    <td><strong>${op.targetComputer}</strong></td>
                                    <td><span class="badge ${op.operation.includes('Delete') ? 'bg-danger' : op.operation.includes('Move OSD') ? 'bg-primary' : 'bg-info'}">${op.operation}</span></td>
                                    <td><small>${op.destination || ''}</small></td>
                                    <td>${op.username}</td>
                                    <td>${op.success ? '<span class="badge bg-success">Success</span>' : '<span class="badge bg-danger">Failed</span>'}</td>
                                </tr>`).join('')}
                            </tbody>
                        </table>
                    </div>`;
            }
        } catch { document.getElementById('recentOperations').innerHTML = '<p class="text-danger text-center">Error loading</p>'; }
    }

    document.addEventListener('DOMContentLoaded', loadRecentOperations);
</script>

<style>
    .dropdown-menu { max-height: 200px; overflow-y: auto; z-index: 1050; border: 1px solid #dee2e6; border-radius: 0.375rem; }
    .dropdown-item-highlighted { background-color: #0d6efd !important; color: white !important; }
    .dropdown-item { transition: background-color 0.1s ease; padding: 0.5rem 1rem; border: none; background: none; width: 100%; text-align: left; }
    .dropdown-item:hover { background-color: #f8f9fa; }
    .card { box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075); }
    .card-header { background-color: #f8f9fa; border-bottom: 1px solid rgba(0,0,0,.125); }
    .btn-warning { color: #000; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
